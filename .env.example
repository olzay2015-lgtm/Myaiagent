# AI Agent Platform - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_agent_platform?schema=public"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# OPENROUTER (LLM Provider)
# ============================================
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ============================================
# AUTHENTICATION (NextAuth)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-key-min-32-chars"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# WEBSOCKET SERVER
# ============================================
WS_PORT=3001
WS_URL="ws://localhost:3001"

# ============================================
# API SERVER
# ============================================
API_PORT=4000
API_URL="http://localhost:4000"

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_WEBHOOK_URL="https://your-domain.com/api/telegram/webhook"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"

# ============================================
# FILE STORAGE (S3/MinIO)
# ============================================
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_NAME="ai-agent-platform"
S3_REGION="us-east-1"

# ============================================
# VOICE PROCESSING
# ============================================
# OpenAI Whisper API (for STT)
OPENAI_API_KEY="your-openai-api-key"
# ElevenLabs (for TTS) - optional
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# ============================================
# SECURITY
# ============================================
JWT_SECRET="your-jwt-secret-min-32-characters"
ENCRYPTION_KEY="your-encryption-key-for-sensitive-data"

# ============================================
# MONITORING (optional)
# ============================================
SENTRY_DSN=""
LOG_LEVEL="info"
